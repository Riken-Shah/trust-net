{
  "name": "trust-net-db-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared Supabase/PostgreSQL connection pool service for trust-net",
  "scripts": {
    "dev": "tsx src/server.ts",
    "buyer-agent:run": "tsx src/buyer-agent/runOnce.ts",
    "buyer-agent:run:one": "bash scripts/test-buyer-agent-one-seller.sh",
    "ingest": "tsx src/ingestion/run.ts",
    "ingest:reset": "tsx src/ingestion/reset.ts",
    "ingest:once": "tsx src/ingestion/runOnce.ts",
    "ingest:worker": "tsx src/ingestion/worker.ts",
    "intel:snapshot:once": "tsx src/intel/snapshotOnce.ts",
    "intel:snapshot:worker": "tsx src/intel/snapshotWorker.ts",
    "intel:test:endpoints": "bash scripts/test-intel-endpoints.sh",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "check": "tsc --noEmit",
    "test:integration": "node --test --import tsx src/db/pool.integration.test.ts",
    "test:unit": "node --test --import tsx \"src/ingestion/__tests__/*.test.ts\" \"src/intel/__tests__/*.test.ts\" \"src/buyer-agent/__tests__/*.test.ts\"",
    "test:ingestion:integration": "node --test --import tsx src/ingestion/ingestion.integration.test.ts",
    "test:intel:integration": "node --test --import tsx src/intel/intel.integration.test.ts"
  },
  "dependencies": {
    "@nevermined-io/payments": "1.1.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.19",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
