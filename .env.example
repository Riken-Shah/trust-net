# Supabase / PostgreSQL (transaction pooler)
# DATABASE_URL is preferred. Use [YOUR-PASSWORD] placeholder with SUPABASE_PASSWORD.
DATABASE_URL=postgresql://postgres.xbaymcfbgybcoxytzuzb:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres
SUPABASE_PASSWORD=your-supabase-db-password

# Fallback components (used when DATABASE_URL is not set)
DB_HOST=aws-1-us-east-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.xbaymcfbgybcoxytzuzb
DB_POOL_MODE=transaction
DB_SSL=true

# TypeScript DB service
DB_SERVICE_PORT=8080

# Marketplace ingestion
MARKETPLACE_API_URL=https://nevermined.ai/hackathon/register/api/marketplace?side=all
INGEST_INTERVAL_SECONDS=300
INGEST_HTTP_TIMEOUT_MS=15000
INGEST_RETRY_COUNT=2
INGEST_PLAN_ENRICH_CONCURRENCY=5
NVM_API_KEY=sandbox:your-api-key
NVM_ENVIRONMENT=sandbox
SELLER_AGENT_ID=your-seller-agent-id

# Intel API + snapshot pipeline
INTEL_SNAPSHOT_INTERVAL_SECONDS=60
INTEL_WINDOW_MINUTES=30
INTEL_SEARCH_RESULT_LIMIT=50
INTEL_AVOID_FAILURE_THRESHOLD=3
# Blockchain order scanning (Etherscan V2)
# Get your key at https://etherscan.io/apis
# Note: Base Sepolia (chainid=84532) may require a paid tier key.
ETHERSCAN_API_KEY=your-etherscan-api-key
# Buyer-agent verification job (one-shot)
OPENAI_API_KEY=sk-your-openai-key
BUYER_AGENT_MODEL=gpt-4o-mini
BUYER_AGENT_TIMEOUT_MS=15000
BUYER_AGENT_PASS_SCORE=6
# Optional cap for one run; unset means no explicit cap
BUYER_AGENT_MAX_SELLERS=
# Optional selector for one seller run (id, marketplace_id, nvm_agent_id, or exact name)
BUYER_AGENT_TARGET_SELLER=
# When target is set, include already-verified seller in candidate set
BUYER_AGENT_INCLUDE_VERIFIED_TARGET=false
# Intel API + snapshot pipeline
INTEL_SNAPSHOT_INTERVAL_SECONDS=60
INTEL_WINDOW_MINUTES=30
INTEL_SEARCH_RESULT_LIMIT=50
INTEL_AVOID_FAILURE_THRESHOLD=3
