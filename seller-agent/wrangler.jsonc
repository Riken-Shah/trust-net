{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "trust-net-mcp",
	"account_id": "ef44744f424f5bb00d8640febf528286",
	"main": "src/index.ts",
	"compatibility_date": "2025-03-10",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"migrations": [
		{
			"new_sqlite_classes": [
				"MyMCP"
			],
			"tag": "v1"
		}
	],
	"durable_objects": {
		"bindings": [
			{
				"class_name": "MyMCP",
				"name": "MCP_OBJECT"
			}
		]
	},
	"observability": {
		"enabled": true
	},
	"hyperdrive": [
		{
			"binding": "HYPERDRIVE",
			"id": "6c06a2bc37b44bb1b1053b78cba6bf88"
		}
	],
	"triggers": {
		"crons": ["*/5 * * * *"]
	}
}
